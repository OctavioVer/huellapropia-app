# HUELLA PROPIA — Variables de Entorno
# ═══════════════════════════════════════════════════════
# Copiá este archivo como .env.local y completá tus datos
# NUNCA subas .env.local a GitHub
# ═══════════════════════════════════════════════════════

# Tu API Key de Anthropic (obligatorio)
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXX

# Contraseña legacy (opcional, para compatibilidad con acceso admin)
APP_PASSWORD=huellapropia2026

# ── Supabase (base de datos) ─────────────────────────────
# Obtené estos valores en https://supabase.com → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Autenticación JWT ─────────────────────────────────────
# Generá una clave secreta aleatoria (ej: openssl rand -base64 32)
JWT_SECRET=tu-clave-secreta-muy-larga-y-aleatoria
